# ==========================================
# FRONTEND - Variáveis de Ambiente (.env.local)
# ==========================================

# URL da API Backend
VITE_API_URL=http://localhost:8080

# Google OAuth Client ID
# Obtém em: https://console.cloud.google.com/
# Criar um projeto OAuth 2.0, tipo "Web application"
# Authorized redirect URIs: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ==========================================
# BACKEND - Variáveis de Ambiente (.env)
# ==========================================

# Porta do servidor
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=clinica_db
DB_SSLMODE=disable

# JWT Secret (MUDE EM PRODUÇÃO!)
JWT_SECRET=your-secret-key-change-in-production

# Google OAuth Client ID (mesmo do frontend)
GOOGLE_CLIENT_ID=your-google-client-id-here

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
#
# 1. GOOGLE OAUTH SETUP:
#    - Ir para https://console.cloud.google.com/
#    - Criar novo projeto
#    - Ativar Google+ API
#    - Criar credencial OAuth 2.0 (Web Application)
#    - Adicionar URIs autorizados:
#      * http://localhost:5173 (dev frontend)
#      * http://localhost:3000 (produção frontend)
#    - Copiar Client ID para VITE_GOOGLE_CLIENT_ID e GOOGLE_CLIENT_ID
#
# 2. JWT_SECRET:
#    - Gerar chave segura em produção
#    - Comando: openssl rand -base64 32
#
# 3. Apenas emails @ufp.edu.pt são aceitos no Google Login
#    - Validação acontece no backend (utils/google_oauth.go)
#
# 4. Email verification:
#    - O Google deve verificar o email antes do login
#    - Token rejeitado se email não verificado
